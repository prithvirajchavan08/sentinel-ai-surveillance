{
  "entities": {
    "Location": {
      "title": "Location",
      "description": "Represents a monitored location node",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "name": { "type": "string" },
        "status": { "type": "string" },
        "message": { "type": "string" },
        "action": { "type": "string" },
        "reason": { "type": "string" },
        "confidence": { "type": "number" },
        "priority": { "type": "string", "enum": ["Critical", "High", "Medium", "Low"] },
        "videoSrc": { "type": "string" },
        "crowdLevel": { "type": "number" },
        "ownerId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "signals": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["name", "ownerId", "id"]
    },
    "Alert": {
      "title": "Alert",
      "description": "Represents an AI-detected security alert",
      "type": "object",
      "properties": {
        "locationId": { "type": "number" },
        "locationName": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "action": { "type": "string" },
        "priority": { "type": "string", "enum": ["Critical", "High", "Medium", "Low"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["locationId", "locationName", "type", "priority", "timestamp", "ownerId"]
    }
  },
  "firestore": {
    "/locations/{locationId}": {
      "schema": { "$ref": "#/entities/Location" },
      "description": "User specific monitored locations"
    },
    "/alerts/{alertId}": {
      "schema": { "$ref": "#/entities/Alert" },
      "description": "Security alerts generated by the AI"
    }
  }
}
